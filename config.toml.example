# RoyaleWithCheese 設定ファイル例
# このファイルをコピーして config.toml として使用してください

[capture]
source = "dda"
timeout_ms = 8
monitor_index = 0

[process]
# 処理モード: "fast-color" (CPU) または "fast-color-gpu" (GPU直接指定)
mode = "fast-color"

[process.roi]
width = 460
height = 240

[process.hsv_range]
h_low = 25
h_high = 45
s_low = 80
s_high = 255
v_low = 80
v_high = 255

[process.coordinate_transform]
sensitivity = 1.0
# ROI中心からのユークリッド距離がこの値未満なら X/Y ともに 0 にする
dead_zone = 0.0
x_clip_limit = 10.0
y_clip_limit = 10.0

[communication]
# 注意: 実際のデバイスの VID/PID に必ず変更してください (0 は無効)
vendor_id = 0x1234
product_id = 0x5678
hid_send_interval_ms = 8

[pipeline]
stats_interval_sec = 10

[toggle]
# トグルキー: "insert", "left_control", "left_alt" など
key = "insert"

[debug]
enabled = false

[activation]
enabled = false
# 検出座標が ROI 中心から max_distance_from_center (チェビシェフ距離) 以内の場合のみ有効化
max_distance_from_center = 15.0
active_window_ms = 500
